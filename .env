POSTGRES_DB=presucontrol
POSTGRES_USER=presucontrol
POSTGRES_PASSWORD=cambia_esta_password
DATABASE_URL=postgresql://presucontrol:cambia_esta_password@postgres:5432/presucontrol
CORS_ORIGINS=http://localhost:8088,http://localhost:5173

# Seguridad
AUTH_ENABLED=true
JWT_SECRET_KEY=cambia_esta_clave_larga_y_aleatoria
ACCESS_TOKEN_EXPIRE_MINUTES=720

# SMTP para avisos por email
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=avisos@tuempresa.com
SMTP_PASSWORD=tu_password_o_app_password
SMTP_FROM=avisos@tuempresa.com
SMTP_TLS=true

# Automatización interna de avisos
SCHEDULER_ENABLED=true
APP_TIMEZONE=Europe/Madrid

# Registro: el primer usuario se aprueba automáticamente; los siguientes quedan pendientes para aceptar desde el panel.
REGISTRATION_REQUIRES_APPROVAL=true

# URL pública usada en emails de recuperación de contraseña
APP_PUBLIC_URL=http://localhost:8088

# Rate limit login
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=10

# En producción se usa Alembic. create_all queda apagado.
RUN_CREATE_ALL=false
RUN_DEFENSIVE_MIGRATIONS=false

POSTGRES_DB=presucontrol
POSTGRES_USER=presucontrol
POSTGRES_PASSWORD=generar_password_largo
DATABASE_URL=postgresql://presucontrol:generar_password_largo@postgres:5432/presucontrol

AUTH_ENABLED=true
JWT_SECRET_KEY=generar_clave_aleatoria_minimo_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=720
CORS_ORIGINS=https://presucontrol.tuempresa.com
APP_PUBLIC_URL=https://presucontrol.tuempresa.com
APP_TIMEZONE=Europe/Madrid

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=avisos@tuempresa.com
SMTP_PASSWORD=password_o_app_password
SMTP_FROM=avisos@tuempresa.com
SMTP_TLS=true

SCHEDULER_ENABLED=true
REGISTRATION_REQUIRES_APPROVAL=true
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=10
RUN_CREATE_ALL=false
RUN_DEFENSIVE_MIGRATIONS=false

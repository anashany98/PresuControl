# ============================================================
# PresuControl V5 - Configuration Template
# ============================================================
# COPY THIS FILE TO .env AND FILL IN THE VALUES
# IMPORTANT: Never commit .env to version control!
# ============================================================

# === ENVIRONMENT ===
ENV=development

# === DATABASE ===
# Generate a strong password with: openssl rand -base64 32
POSTGRES_DB=presucontrol
POSTGRES_USER=presucontrol
POSTGRES_PASSWORD=CHANGE_THIS_WITH_generated_secure_password  # Required: generate with openssl rand -base64 32
DATABASE_URL=postgresql://presucontrol:CHANGE_THIS_WITH_generated_secure_password@postgres:5432/presucontrol
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# === CORS ===
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGINS=http://localhost:8088,http://localhost:5173

# === SECURITY - CRITICAL ===
# Generate a strong JWT secret with: openssl rand -base64 64
# This key secures all authentication tokens - treat it like a password!
JWT_SECRET_KEY=CHANGE_THIS_WITH_generated_secure_key  # Required: generate with openssl rand -base64 64
ACCESS_TOKEN_EXPIRE_MINUTES=720

# === ERROR MONITORING (Sentry) ===
# Get your DSN from https://sentry.io → Settings → Projects → Client Keys (DSN)
# Leave empty to disable Sentry (notifications will still use SMTP).
SENTRY_DSN=
# Sample rate for performance tracing (0.0 to 1.0). Default: 0.1 (10%).
SENTRY_TRACES_SAMPLE_RATE=0.1

# === LOGGING ===
LOG_LEVEL=INFO
SQLALCHEMY_LOG_LEVEL=WARNING

# === SMTP (for notifications) ===
# Generate an app password for your email provider if using 2FA
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notificaciones@example.com
SMTP_PASSWORD=CHANGE_THIS_WITH_app_password  # Use an app password, not your main password
SMTP_FROM=notificaciones@example.com
SMTP_TLS=true

# === AUTOMATION ===
SCHEDULER_ENABLED=true
APP_TIMEZONE=Europe/Madrid

# === REGISTRATION ===
# First user is auto-approved; subsequent users require approval from a system manager
REGISTRATION_REQUIRES_APPROVAL=true

# === PUBLIC URL (used in notification emails) ===
APP_PUBLIC_URL=http://localhost:8088

# === RATE LIMITING ===
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=10

# Trusted proxies for X-Forwarded-For resolution (comma-separated IPs/CIDRs).
# In production behind nginx: "127.0.0.1,::1" or the docker network gateway.
# Leave empty in development (no proxy). An attacker can spoof X-Forwarded-For
# if this is set incorrectly — only trust proxies that are actually in front of this app.
# Examples: "127.0.0.1"  |  "127.0.0.1,::1,172.16.0.0/12"
TRUSTED_PROXIES=

# === DATABASE CREATION (leave disabled in production) ===
RUN_CREATE_ALL=false
RUN_DEFENSIVE_MIGRATIONS=false

# === BACKUP ENCRYPTION (required for automated backups) ===
# Generate an encryption password with: openssl rand -base64 32
# Set this environment variable before running backup.sh
# BACKUP_ENCRYPTION_PASSWORD=CHANGE_THIS_WITH_generated_encryption_password

# === BACKUP SIDECAR ===
# Cron expression for the in-container backup sidecar. Default: 03:00 every day.
BACKUP_SCHEDULE=0 3 * * *
# Days of backup files to keep on the volume. Default: 30.
BACKUP_RETENTION_DAYS=30
# Where the sidecar writes backups inside the container. Default: /backups.
# Do NOT change unless you also change the volume mount in docker-compose.prod.yml.
BACKUP_DIR=/backups
# Healthcheck threshold: maximum age (in seconds) of the last successful backup
# before the sidecar is reported unhealthy by Docker. Default 90000 (25h) leaves
# 1h of slack on top of the default 24h schedule. Bump down for more aggressive
# checks, up for infrequent schedules (e.g. weekly = 604800+).
BACKUP_HEALTHCHECK_MAX_AGE=90000